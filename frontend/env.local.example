# Copia este archivo a `.env.local` (gitignored) y completá los valores.
# Los tres primeros salen de los outputs del stack CrQuest-Auth-<stage>
# (UserPoolIdOutput / WebClientIdOutput / HostedUiDomainOutput).

# --- Backend real (vista previa local) ---
BACKEND_API_URL=https://h0swa6z9f2.execute-api.us-east-1.amazonaws.com

# Token fijo del usuario de prueba de Cognito. Fallback temporal mientras se
# configura el login con Google; el BFF lo usa solo si no hay cookie de sesión.
# Quitar cuando el flujo de Google esté funcionando end-to-end.
BACKEND_API_TOKEN=

# --- Login con Google vía Cognito (OAuth) ---
# Dominio Hosted UI del pool (HostedUiDomainOutput del stack de Auth).
COGNITO_DOMAIN=https://cr-quest-dev.auth.us-east-1.amazoncognito.com
# ID del App Client web (WebClientIdOutput).
COGNITO_CLIENT_ID=
# Debe coincidir con un callbackUrl del App Client (AuthStack).
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Origen público del frontend, para el logout_uri.
APP_BASE_URL=http://localhost:3000
